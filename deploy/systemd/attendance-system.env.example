ATTENDANCE_DB_HOST=127.0.0.1
ATTENDANCE_DB_PORT=3306
ATTENDANCE_DB_USER=attendance_user
ATTENDANCE_DB_PASSWORD=change_me
ATTENDANCE_DB_NAME=attendance_system

